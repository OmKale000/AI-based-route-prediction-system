# Application Settings
APP_NAME="AI Route Prediction Engine"
ENV="development" # development, staging, production
DEBUG=True
HOST="0.0.0.0"
PORT=8000

# Database Settings
# Using SQLite by default for easy setup. Uncomment PostgreSQL for production.
DATABASE_URL="sqlite:///./data/route_engine.db"
# DATABASE_URL="postgresql://user:password@db:5432/route_engine"

# Redis Caching (Optional, defaults to in-memory if empty)
REDIS_URL="redis://redis:6379/0"
USE_REDIS_CACHE=True

# Google Maps API Key
# MOCK MODE will be activated if this is empty
GOOGLE_MAPS_API_KEY="AIzaSyC5Emj3nkT5KDvlN9NkaepY3jhn8jBQKOg"

# Model Registry
MODEL_ARTIFACT_DIR="./artifacts"

# Logging
LOG_LEVEL="INFO"
